# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Set base path for clean URLs
    RewriteBase /admin-panel/

    # Disable directory listing
    Options -Indexes

    # Block direct web access to application internals
    RewriteRule ^(?:vendor|includes)(?:/|$) - [F,L,NC]

    # Don't rewrite real files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect .php URLs to clean URLs (301 permanent redirect for SEO)
    # /verify-otp.php -> /verify-otp
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([a-z0-9-]+)\.php
    RewriteRule ^([a-z0-9-]+)\.php$ $1 [R=301,L]

    # Rewrite clean URLs to .php files
    # Matches: /page-name or /page-name/ -> page-name.php
    # Query strings are preserved with QSA flag
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([a-z0-9-]+)/?$ $1.php [QSA,L]
</IfModule>

# Fallback if mod_rewrite is not available: serve .php files directly
# This allows the system to work even if rewrite rules fail
<IfModule !mod_rewrite.c>
    # If mod_rewrite is disabled, clean URLs won't work but PHP files still accessible
</IfModule>

# Security: Block access to sensitive files and directories
<Files ".env.php">
  Require all denied
</Files>

<FilesMatch "^(composer\.(json|lock)|composer\.phar|database\.sql|\.htaccess|\.env)$">
  Require all denied
</FilesMatch>

# PHP configuration
<IfModule mod_php.c>
    php_value upload_max_filesize 32M
    php_value post_max_size 32M
    php_value max_execution_time 300
</IfModule>

# Enable gzip compression for faster delivery
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Set cache headers for static assets to improve performance
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>
