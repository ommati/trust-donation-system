# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /trust-donation-system/

    # Remove trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [R=301,L]

    # Don't rewrite if file exists
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Don't rewrite if directory exists
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect old .php URLs to clean URLs
    RewriteCond %{THE_REQUEST} ^GET\ /trust-donation-system/([a-z0-9-]+)\.php [NC]
    RewriteRule ^([a-z0-9-]+)\.php$ /trust-donation-system/$1 [R=301,L,NC]

    # Rewrite clean URLs to .php files
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([a-z0-9-]+)/?$ $1.php [QSA,L]
</IfModule>


# Fallback if mod_rewrite is not available: serve .php files directly
# This allows the system to work even if rewrite rules fail
<IfModule !mod_rewrite.c>
    # If mod_rewrite is disabled, clean URLs won't work but PHP files still accessible
</IfModule>

# Security: Block access to sensitive files and directories
<Files ".env.php">
  Require all denied
</Files>

<FilesMatch "^(composer\.(json|lock)|composer\.phar|database\.sql|\.htaccess|\.env)$">
  Require all denied
</FilesMatch>

# Block vendor and includes directories from web access
<DirectoryMatch "^.*(vendor|includes)">
    Require all denied
</DirectoryMatch>

# PHP configuration
<IfModule mod_php.c>
    php_value upload_max_filesize 32M
    php_value post_max_size 32M
    php_value max_execution_time 300
</IfModule>

# Enable gzip compression for faster delivery
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Set cache headers for static assets to improve performance
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>
