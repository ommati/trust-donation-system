# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Get the base path - adjust based on cPanel/server installation
    # For /trust-donation-system/ use: RewriteBase /trust-donation-system/
    # For root use: RewriteBase /
    RewriteBase /trust-donation-system/

    # Disable directory listing
    Options -Indexes

    # Allow direct access to existing files
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Allow direct access to existing directories
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rewrite clean URLs to .php files (preserve query strings)
    RewriteRule ^([a-z0-9-]+)/?$ $1.php [L,QSA]
</IfModule>

# Security: Block access to sensitive files and directories
<Files ".env.php">
  Require all denied
</Files>

<FilesMatch "^(composer\.(json|lock)|composer\.phar|database\.sql)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.env|\.htaccess|\.sql$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security: Block vendor and includes directories from web access
<Directory "vendor">
    Order allow,deny
    Deny from all
</Directory>
<Directory "includes">
    Order allow,deny
    Deny from all
</Directory>

# PHP configuration
<IfModule mod_php.c>
    php_value upload_max_filesize 32M
    php_value post_max_size 32M
    php_value max_execution_time 300
</IfModule>

# Enable gzip compression for faster delivery
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Set cache headers for static assets to improve performance
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>
